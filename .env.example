FLASK_ENV=production
SECRET_KEY=change-me-to-something-random
ADMIN_PASSWORD=change-me
RFID_MOCK=false
# auto = detect CP2102 USB bridge first, then fall back to /dev/ttyS0 GPIO UART
# Examples: /dev/ttyUSB0  /dev/ttyS0  COM3
RFID_PORT=auto

# Offsite sync: "none" to disable, "cloud" to sync to autonom-drinks-cloud
SYNC_PROVIDER=none
SYNC_INTERVAL_SECONDS=300

# Cloud sync settings (can also be set via admin settings page)
CLOUD_URL=https://your-cloud-server.example.com
CLOUD_API_KEY=replace-with-api-key-from-cloud-env
BAR_LOCATION=Vereinsheim

# Unique ID for this bar — must match an entry in the cloud's API_KEYS registry
# Generate with: python -c "import uuid; print(uuid.uuid4().hex)"
BAR_UID=replace-with-bar-uid
